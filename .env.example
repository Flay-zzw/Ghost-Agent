# MiniMax API 配置
# 从 https://platform.minimax.io 获取你的 API Key
MINIMAX_API_KEY=your-api-key-here

# API Base URL（根据你的地区选择）
# 海外用户：https://api.minimax.io/v1
# 中国大陆：https://api.minimaxi.com/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1

# 模型选择（推荐使用最新的 MiniMax-M2.5）
# 可选：MiniMax-M2.5 / MiniMax-M2.5-highspeed / MiniMax-M2.1 / MiniMax-M2
MINIMAX_MODEL=MiniMax-M2.5
